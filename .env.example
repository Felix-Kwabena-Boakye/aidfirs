# IbraHim Digital Forensics System - Environment Configuration
# Copy this file to .env and fill in your secrets.

# =============================================================================
# SECURITY - REQUIRED
# =============================================================================
# Generate a strong SECRET_KEY with:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-strong-secret-key-here-generate-with-secrets-module

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# =============================================================================
# DATABASE
# =============================================================================
# MongoDB connection URI
MONGO_URI=mongodb://localhost:27017/
MONGO_DB_NAME=ai_digital_forensics

# SQLite is used internally by Django for admin/auth/sessions
# (no additional config needed, auto-created at backend/db.sqlite3)

# =============================================================================
# AI ENGINE - Anthropic Claude
# =============================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20240620
CLAUDE_ENABLED=true

# OAUTH - Google
# =============================================================================
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret-here


# =============================================================================
# CORS
# =============================================================================
# Comma-separated allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# REDIS / CELERY
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# RATE LIMITING (optional)
# =============================================================================
# IP-based rate limits for auth endpoints
# Format: requests/time_period (e.g., 5/m, 100/h)
AUTH_RATE_LIMIT=5/m
TOKEN_REFRESH_RATE_LIMIT=20/h

