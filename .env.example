# =============================================================================
# SECURITY - REQUIRED
# =============================================================================

SECRET_KEY=your-strong-secret-key-here-generate-with-secrets-module

DEBUG=False

ALLOWED_HOSTS=aidfirs.onrender.com,localhost,127.0.0.1

# =============================================================================
# DATABASE (MongoDB - Production Ready)
# =============================================================================

# ⚠️ Use MongoDB Atlas in production, NOT localhost
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/
MONGO_DB_NAME=ai_digital_forensics

# =============================================================================
# AI ENGINE - Anthropic Claude
# =============================================================================

ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20240620
CLAUDE_ENABLED=true

# =============================================================================
# GOOGLE OAUTH
# =============================================================================

GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret-here

# =============================================================================
# CORS (VERY IMPORTANT FOR VERCEL)
# =============================================================================

CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# =============================================================================
# REDIS / CELERY (Render compatible)
# =============================================================================

# If using Render Redis:
CELERY_BROKER_URL=redis://red-xxxxx:6379/0
CELERY_RESULT_BACKEND=redis://red-xxxxx:6379/0

# =============================================================================
# RATE LIMITING
# =============================================================================

AUTH_RATE_LIMIT=5/m
TOKEN_REFRESH_RATE_LIMIT=20/h

# =============================================================================
# EMAIL (optional but recommended)
# =============================================================================

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
