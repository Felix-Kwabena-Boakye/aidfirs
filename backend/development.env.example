# AIDFIRS Platform - Development Environment Variables
# Copy to .env and customize.

# Django Base Config
SECRET_KEY=dev-secret-key-default-for-aidfirs-local
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# CORS Allowed Origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Database Connection (Local MongoDB)
MONGO_URI=mongodb://localhost:27017/ai_digital_forensics
MONGO_DB_NAME=ai_digital_forensics

# Relational Database
DATABASE_URL=sqlite:///db.sqlite3

# Redis & Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Claude AI API (Anthropic - optional in dev if mockup fallback is used)
ANTHROPIC_API_KEY=mock-key-or-real-api-key
CLAUDE_MODEL=claude-3-5-sonnet-20240620
CLAUDE_ENABLED=True

# Google OAuth Integration
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id-here.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret-here

# Cloudinary (optional in dev)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email Config (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
EMAIL_RESET_URL_BASE=http://localhost:3000/reset-password
