# AIDFIRS Platform - Production Environment Variables
# Copy to .env and customize. NEVER commit .env files to Git repositories!

# Django Base Config
SECRET_KEY=generate-a-strong-random-key-for-production
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,localhost,127.0.0.1

# CORS Allowed Origins (Comma-separated)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database Connection (MongoDB Atlas)
MONGO_URI=mongodb+srv://<username>:<password>@<your-cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_DB_NAME=ai_digital_forensics

# Relational Database (for internal django tables - defaults to sqlite in container volumes)
DATABASE_URL=sqlite:////app/backend/db.sqlite3

# Redis & Celery (Broker and Backend - default configuration uses local Redis)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Claude AI API (Anthropic)
ANTHROPIC_API_KEY=your-anthropic-claude-api-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20240620
CLAUDE_ENABLED=True

# Google OAuth Integration
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id-here.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret-here

# Cloudinary Storage Integration (for reports and carved file assets)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# SMTP Email Settings (e.g., Gmail for passwords/alerts)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email-address@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=your-email-address@gmail.com
EMAIL_RESET_URL_BASE=https://yourdomain.com/reset-password
